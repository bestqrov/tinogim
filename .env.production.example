# Production Environment Variables
# Copy this file to .env.production and fill with your production values

# Database Configuration
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/production_db"

# Server Configuration
PORT=3000
NODE_ENV=production

# JWT Configuration - MUST be generated securely for production
JWT_SECRET="your-strong-production-jwt-secret-minimum-32-characters-long"
JWT_EXPIRES_IN="7d"

# Frontend Configuration
FRONTEND_URL="https://your-frontend-domain.com"
PROXY_TARGET="https://your-frontend-domain.com"

# Optional: Skip database check (for CI/CD environments)
SKIP_DB_CHECK=false