{
  "name": "arwa-educ-backend",
  "version": "1.0.0",
  "description": "ArwaEduc School Management System Backend with Node.js, Express, Prisma, and MongoDB",
  "main": "dist/server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "npm run prisma:generate && npx tsc && npm run build:frontend",
    "build:backend": "npm run prisma:generate && npx tsc",
    "build:frontend": "cd frontend && npm ci && npm run build",
    "build:full": "npm run build:backend && npm run build:frontend",
    "start": "node dist/server.js",
    "start:prod": "NODE_ENV=production npm run start",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "docker:build": "docker build -t arwa-educ-backend .",
    "docker:run": "docker run -p 3000:3000 --env-file .env arwa-educ-backend",
    "deploy:docker": "docker-compose up -d",
    "deploy:build": "docker-compose build",
    "production:setup": "npm ci && npm run prisma:generate && npm run build"
  },
  "keywords": [
    "school",
    "management",
    "backend",
    "express",
    "prisma",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "axios": "^1.13.2",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.5",
    "prisma": "^5.7.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
