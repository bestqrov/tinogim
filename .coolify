# Coolify deployment configuration
# This file tells Coolify how to deploy the ArwaEduc application

# Service type: dockerCompose for multi-service or docker for single service
type: docker

# Health check endpoint
healthcheck: /health

# Port the application runs on
port: 3000

# Build command (Coolify will use Dockerfile by default)
buildCommand: docker build .

# Startup command (defined in Dockerfile CMD)
startCommand: npm start

# Enable auto-deployment from GitHub
autoDeployment: true

# Deployment settings
deployment:
  strategy: rolling
  maxUnavailable: 0
  maxSurge: 1

# Minimum resources required
resources:
  memory: 512Mi
  cpu: 0.5

# Environment variables that need to be set in Coolify
requiredEnvVars:
  - DATABASE_URL
  - JWT_SECRET
  - NODE_ENV
  - PORT